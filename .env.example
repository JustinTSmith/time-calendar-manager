# Database
POSTGRES_DB=time_calendar_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/time_calendar_manager

# Redis
REDIS_URL=redis://localhost:6379

# API Server
PORT=3001
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001

# JWT Authentication
JWT_SECRET=your_jwt_secret_at_least_32_characters
JWT_ACCESS_SECRET=your-access-secret-key-minimum-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-32-characters

# Encryption (AES-256-GCM for OAuth tokens) - generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_encryption_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/auth/google/callback
GOOGLE_WEBHOOK_SECRET=your_google_webhook_secret

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-app-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-app-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/v1/auth/microsoft/callback
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/common
MICROSOFT_WEBHOOK_SECRET=your-microsoft-webhook-secret

# Web App (Socket.io)
NEXT_PUBLIC_WS_URL=http://localhost:3001
