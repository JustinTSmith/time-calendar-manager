# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/time_calendar_manager

# Server
PORT=3000
PUBLIC_URL=http://localhost:3000

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-app-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-app-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/v1/auth/microsoft/callback
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/common

# Encryption (32+ character string for AES-256-GCM)
ENCRYPTION_KEY=your-32-byte-encryption-key-minimum-length

# Redis (for BullMQ job queues)
REDIS_URL=redis://localhost:6379

# Webhook validation secret
WEBHOOK_SECRET=your-webhook-secret-for-validation
